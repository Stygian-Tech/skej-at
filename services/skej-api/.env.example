APP_ENV=local
PORT=8080

# Public origin for this gateway's OAuth metadata. ATProto providers fetch
# SKEJ_PUBLIC_ORIGIN/oauth/client-metadata.json and use it as the client_id.
# Local API example: http://127.0.0.1:8080.
# Hosted dev: use the public API origin, for example https://api.testing.skej.at.
SKEJ_PUBLIC_ORIGIN=http://127.0.0.1:8080

# Browser-facing app origin for OAuth redirects after authorization.
# Leave empty when it is the same as SKEJ_PUBLIC_ORIGIN.
# Local web example: http://127.0.0.1:3000.
# Hosted dev example: https://testing.skej.at.
SKEJ_WEB_ORIGIN=http://127.0.0.1:3000

SKEJ_SQLITE_PATH=data/skej.sqlite
SKEJ_WORKER_ENABLED=true
SKEJ_WORKER_INTERVAL_SECONDS=30
SKEJ_LIVE_ATPROTO_ENABLED=false
