APP_ENV=local
PORT=8080

# Browser-facing origin used in ATProto OAuth client metadata and redirect URIs.
# Local web proxies /oauth/* to this API, so the callback origin should be the web origin.
SKEJ_PUBLIC_ORIGIN=http://127.0.0.1:3000
SKEJ_WEB_ORIGIN=

SKEJ_SQLITE_PATH=data/skej.sqlite
SKEJ_WORKER_ENABLED=true
SKEJ_WORKER_INTERVAL_SECONDS=30
SKEJ_LIVE_ATPROTO_ENABLED=false
